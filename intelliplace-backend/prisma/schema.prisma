generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                  Int                          @id @default(autoincrement())
  name                String
  email               String                       @unique
  password            String
  rollNumber          String?                      @map("roll_number")
  cgpa                Float?
  backlog             Int?
  cvUrl               String?                      @map("cv_url")
  cvData              Bytes?                       @map("cv_data")
  phone               String?
  createdAt           DateTime                     @default(now()) @map("created_at")
  updatedAt           DateTime                     @updatedAt @map("updated_at")
  applications        Application[]
  aptitudeSubmissions AptitudeSubmission[]
  codingSubmissions   CodingSubmission[]
  gdParticipants      GroupDiscussionParticipant[]
  notifications       Notification[]

  @@index([email])
  @@map("students")
}

model Company {
  id          Int      @id @default(autoincrement())
  companyName String   @map("company_name")
  email       String   @unique
  password    String
  industry    String?
  website     String?
  phone       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  jobs        Job[]

  @@index([email])
  @@map("companies")
}

model Job {
  id                        Int              @id @default(autoincrement())
  title                     String
  description               String
  location                  String?
  type                      String
  salary                    String?
  requiredSkills            String?          @map("required_skills")
  minCgpa                   Float?           @map("min_cgpa")
  includeCgpaInShortlisting Boolean?         @default(true) @map("include_cgpa_in_shortlisting")
  allowBacklog              Boolean?         @map("allow_backlog")
  maxBacklog                Int?             @map("max_backlog")
  jobDescriptionFileUrl     String?          @map("job_description_file_url")
  deadline                  DateTime?        @map("deadline")
  companyId                 Int              @map("company_id")
  status                    String           @default("OPEN")
  createdAt                 DateTime         @default(now()) @map("created_at")
  updatedAt                 DateTime         @updatedAt @map("updated_at")
  pipelineAptitudeDone      Boolean          @default(false) @map("pipeline_aptitude_done")
  pipelineCodingDone        Boolean          @default(false) @map("pipeline_coding_done")
  pipelineGdDone            Boolean          @default(false) @map("pipeline_gd_done")
  pipelineInterviewDone     Boolean          @default(false) @map("pipeline_interview_done")
  adminApproved             Boolean          @default(false) @map("admin_approved")
  applications              Application[]
  aptitudeTest              AptitudeTest?
  codingTest                CodingTest?
  groupDiscussion           GroupDiscussion?
  interviews                Interview[]
  company                   Company          @relation(fields: [companyId], references: [id])
  notifications             Notification[]

  @@index([companyId])
  @@map("jobs")
}

model Application {
  id             Int            @id @default(autoincrement())
  studentId      Int            @map("student_id")
  jobId          Int            @map("job_id")
  skills         String?        @map("skills")
  cgpa           Float?         @map("cgpa")
  backlog        Int?           @map("backlog")
  cvUrl          String?        @map("cv_url")
  cvData         Bytes?         @map("cv_data")
  decisionReason String?        @map("decision_reason")
  status         String         @default("PENDING")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  job            Job            @relation(fields: [jobId], references: [id])
  student        Student        @relation(fields: [studentId], references: [id])
  interview      Interview?
  notifications  Notification[]

  @@index([studentId])
  @@index([jobId])
  @@map("applications")
}

model Interview {
  id                Int                         @id @default(autoincrement())
  applicationId     Int                         @unique @map("application_id")
  jobId             Int                         @map("job_id")
  date              DateTime
  type              String
  status            String                      @default("SCHEDULED")
  notes             String?
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  proctorViolations InterviewProctorViolation[]
  sessions          InterviewSession[]
  application       Application                 @relation(fields: [applicationId], references: [id])
  job               Job                         @relation(fields: [jobId], references: [id])

  @@index([applicationId])
  @@index([jobId])
  @@map("interviews")
}

model InterviewProctorViolation {
  id          Int       @id @default(autoincrement())
  interviewId Int       @map("interview_id")
  studentId   Int       @map("student_id")
  type        String
  metadata    String?   @map("metadata")
  createdAt   DateTime  @default(now()) @map("created_at")
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([studentId])
  @@map("interview_proctor_violations")
}

model InterviewSession {
  id                   Int                       @id @default(autoincrement())
  interviewId          Int                       @map("interview_id")
  mode                 String
  status               String                    @default("ACTIVE")
  currentQuestionIndex Int                       @default(0) @map("current_question_index")
  questions            String
  answers              String?
  startedAt            DateTime                  @default(now()) @map("started_at")
  completedAt          DateTime?                 @map("completed_at")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  /// Gemini aggregate summary when the session completes (JSON)
  overallEvaluation    String?                   @map("overall_evaluation")
  proctoringScore      Float?                    @map("proctoring_score")
  /// JSON: counts, weighted penalty breakdown, normalized 0–100 score
  proctoringSummary    String?                   @map("proctoring_summary")
  questionAnswers      InterviewQuestionAnswer[]
  interview            Interview                 @relation(fields: [interviewId], references: [id])

  @@index([interviewId])
  @@map("interview_sessions")
}

model InterviewQuestionAnswer {
  id              Int              @id @default(autoincrement())
  sessionId       Int              @map("session_id")
  questionIndex   Int              @map("question_index")
  questionText    String           @map("question_text")
  transcribedText String?          @map("transcribed_text")
  audioUrl        String?          @map("audio_url")
  videoUrl        String?          @map("video_url")
  contentScore    Float?           @map("content_score")
  confidenceScore Float?           @map("confidence_score")
  emotionScores   String?          @map("emotion_scores")
  overallScore    Float?           @map("overall_score")
  feedback        String?
  analysisData    String?          @map("analysis_data")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  session         InterviewSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([questionIndex])
  @@map("interview_question_answers")
}

model Notification {
  id             Int          @id @default(autoincrement())
  studentId      Int          @map("student_id")
  title          String
  message        String
  read           Boolean      @default(false)
  decisionReason String?      @map("decision_reason")
  jobId          Int?         @map("job_id")
  applicationId  Int?         @map("application_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  application    Application? @relation(fields: [applicationId], references: [id])
  job            Job?         @relation(fields: [jobId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([read])
  @@map("notifications")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([username])
  @@map("admins")
}

model CodingTest {
  id               Int                @id @default(autoincrement())
  jobId            Int                @unique @map("job_id")
  title            String
  description      String?
  allowedLanguages String             @map("allowed_languages")
  timeLimit        Int                @default(60) @map("time_limit")
  cutoff           Float?
  status           String             @default("CREATED")
  startedAt        DateTime?          @map("started_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  questions        CodingQuestion[]
  submissions      CodingSubmission[]
  job              Job                @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@map("coding_tests")
}

model CodingQuestion {
  id              Int        @id @default(autoincrement())
  testId          Int        @map("test_id")
  title           String
  description     String
  difficulty      String     @default("MEDIUM")
  points          Int        @default(10)
  testCases       String     @map("test_cases")
  expectedOutputs String     @map("expected_outputs")
  sampleInput     String?    @map("sample_input")
  sampleOutput    String?    @map("sample_output")
  sampleCases     Json?      @map("sample_cases")
  constraints     String?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  test            CodingTest @relation(fields: [testId], references: [id])

  @@index([testId])
  @@map("coding_questions")
}

model CodingSubmission {
  id              Int        @id @default(autoincrement())
  testId          Int        @map("test_id")
  questionId      Int        @map("question_id")
  studentId       Int        @map("student_id")
  languageId      Int        @map("language_id")
  code            String
  status          String?
  score           Float?
  executionTime   Float?     @map("execution_time")
  memoryUsed      Int?       @map("memory_used")
  judge0Token     String?    @map("judge0_token")
  errorMessage    String?    @map("error_message")
  testCaseResults String?    @map("test_case_results")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  student         Student    @relation(fields: [studentId], references: [id])
  test            CodingTest @relation(fields: [testId], references: [id])

  @@index([testId])
  @@index([questionId])
  @@index([studentId])
  @@map("coding_submissions")
}

model AptitudeTest {
  id             Int                  @id @default(autoincrement())
  jobId          Int                  @unique @map("job_id")
  sections       Json
  cutoff         Int?
  totalQuestions Int?                 @map("total_questions")
  status         String               @default("CREATED")
  startedAt      DateTime?            @map("started_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  questions      AptitudeQuestion[]
  submissions    AptitudeSubmission[]
  job            Job                  @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@map("aptitude_tests")
}

model AptitudeQuestion {
  id           Int          @id @default(autoincrement())
  testId       Int          @map("test_id")
  section      String
  questionText String       @map("question_text")
  options      Json
  correctIndex Int          @map("correct_index")
  marks        Int          @default(1)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  test         AptitudeTest @relation(fields: [testId], references: [id])

  @@index([testId])
  @@map("aptitude_questions")
}

model AptitudeSubmission {
  id          Int          @id @default(autoincrement())
  testId      Int          @map("test_id")
  studentId   Int          @map("student_id")
  answers     Json
  score       Float?
  percentage  Float?
  status      String?
  submittedAt DateTime?    @map("submitted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  student     Student      @relation(fields: [studentId], references: [id])
  test        AptitudeTest @relation(fields: [testId], references: [id])

  @@index([testId])
  @@index([studentId])
  @@map("aptitude_submissions")
}

model GroupDiscussion {
  id            Int                          @id @default(autoincrement())
  jobId         Int                          @unique @map("job_id")
  topic         String
  status        String                       @default("CREATED")
  prepDuration  Int                          @default(120)
  startedAt     DateTime?                    @map("started_at")
  prepStartedAt DateTime?                    @map("prep_started_at")
  createdAt     DateTime                     @default(now()) @map("created_at")
  updatedAt     DateTime                     @updatedAt @map("updated_at")
  participants  GroupDiscussionParticipant[]
  job           Job                          @relation(fields: [jobId], references: [id])

  @@map("group_discussions")
}

model GroupDiscussionParticipant {
  id              Int             @id @default(autoincrement())
  gdId            Int             @map("gd_id")
  studentId       Int             @map("student_id")
  status          String          @default("WAITING")
  joinedAt        DateTime        @default(now()) @map("joined_at")
  queuePosition   Int?            @map("queue_position")
  audioUrl        String?         @map("audio_url")
  transcribedText String?         @map("transcribed_text")
  score           Float?
  feedback        String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  gd              GroupDiscussion @relation(fields: [gdId], references: [id])
  student         Student         @relation(fields: [studentId], references: [id])

  @@index([gdId])
  @@index([studentId])
  @@map("group_discussion_participants")
}
